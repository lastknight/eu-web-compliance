{
  "version": "0.1.0",
  "note": "Seed knowledge base for tracker/cookie classification. Not a replacement for full filter lists (EasyPrivacy, Disconnect, DDG Tracker Radar) — it is a curated high-signal core, extensible via PR and overridable with --filterlist. Categories follow the Area C / CNIL / WAT taxonomy. 'consent' = required | exempt-conditional | technical.",
  "categories": {
    "advertising": "Personalised or non-personalised advertising, remarketing, conversion tracking. Consent required.",
    "advertising-pixel": "Platform advertising pixels that fire on page load and track logged-out users (C-05). Consent required.",
    "analytics": "Audience measurement. Consent required unless the exemption conditions are met (IP masking, no cross-referencing, no sharing) — see C-11, C-14.",
    "session-recording": "Session replay / heatmaps that can capture typed fields (C-07 form masking, G-10). Consent required.",
    "social": "Social sharing / embedded widgets that set third-party cookies. Consent required.",
    "tag-manager": "Tag management containers. The container itself is technical; what it injects is not — classify the injected tags.",
    "fingerprinting": "Device/canvas/font/audio fingerprinting. Access to terminal information, same regime as cookies (C-04, C-12).",
    "fonts": "Remotely hosted web fonts that leak IP to a third party (E-04, Q-E-11). Prefer self-hosting.",
    "captcha": "Third-party CAPTCHA / bot detection that leaks IP and may set cookies (E-07, Q-E-12).",
    "cdn": "Content delivery / asset hosting. Usually technical, but a US CDN is still a transfer surface (Area E)."
  },
  "domains": {
    "connect.facebook.net": { "vendor": "Meta", "category": "advertising-pixel", "consent": "required", "note": "Meta Pixel (fbevents)" },
    "www.facebook.com": { "vendor": "Meta", "category": "advertising-pixel", "consent": "required", "note": "tr/ pixel endpoint" },
    "analytics.tiktok.com": { "vendor": "TikTok", "category": "advertising-pixel", "consent": "required", "note": "TikTok Pixel" },
    "px.ads.linkedin.com": { "vendor": "LinkedIn", "category": "advertising-pixel", "consent": "required", "note": "LinkedIn Insight Tag pixel" },
    "snap.licdn.com": { "vendor": "LinkedIn", "category": "advertising-pixel", "consent": "required", "note": "LinkedIn Insight Tag loader" },
    "googleads.g.doubleclick.net": { "vendor": "Google", "category": "advertising", "consent": "required", "note": "Google Ads / DoubleClick" },
    "www.googleadservices.com": { "vendor": "Google", "category": "advertising", "consent": "required", "note": "Google Ads conversion" },
    "static.ads-twitter.com": { "vendor": "X (Twitter)", "category": "advertising-pixel", "consent": "required" },
    "analytics.twitter.com": { "vendor": "X (Twitter)", "category": "advertising-pixel", "consent": "required" },
    "bat.bing.com": { "vendor": "Microsoft", "category": "advertising-pixel", "consent": "required", "note": "Microsoft/Bing UET tag" },
    "sc-static.net": { "vendor": "Snap", "category": "advertising-pixel", "consent": "required" },
    "tr.snapchat.com": { "vendor": "Snap", "category": "advertising-pixel", "consent": "required" },
    "ct.pinterest.com": { "vendor": "Pinterest", "category": "advertising-pixel", "consent": "required" },
    "s.pinimg.com": { "vendor": "Pinterest", "category": "advertising-pixel", "consent": "required" },
    "www.redditstatic.com": { "vendor": "Reddit", "category": "advertising-pixel", "consent": "required" },
    "cdn.taboola.com": { "vendor": "Taboola", "category": "advertising", "consent": "required" },
    "www.outbrain.com": { "vendor": "Outbrain", "category": "advertising", "consent": "required" },
    "www.google-analytics.com": { "vendor": "Google", "category": "analytics", "consent": "exempt-conditional", "note": "Universal Analytics collect endpoint" },
    "ssl.google-analytics.com": { "vendor": "Google", "category": "analytics", "consent": "exempt-conditional" },
    "region1.google-analytics.com": { "vendor": "Google", "category": "analytics", "consent": "exempt-conditional", "note": "GA4 regional collect" },
    "analytics.google.com": { "vendor": "Google", "category": "analytics", "consent": "exempt-conditional", "note": "GA4 collect (g/collect)" },
    "www.googletagmanager.com": { "vendor": "Google", "category": "tag-manager", "consent": "technical", "note": "GTM container + gtag.js — classify injected tags, not the loader" },
    "stats.g.doubleclick.net": { "vendor": "Google", "category": "advertising", "consent": "required", "note": "GA remarketing / DoubleClick sync" },
    "plausible.io": { "vendor": "Plausible", "category": "analytics", "consent": "exempt-conditional", "note": "cookieless, EU-hosted — often exempt" },
    "cdn.matomo.cloud": { "vendor": "Matomo", "category": "analytics", "consent": "exempt-conditional" },
    "static.hotjar.com": { "vendor": "Hotjar", "category": "session-recording", "consent": "required" },
    "script.hotjar.com": { "vendor": "Hotjar", "category": "session-recording", "consent": "required" },
    "www.clarity.ms": { "vendor": "Microsoft Clarity", "category": "session-recording", "consent": "required" },
    "cdn.mouseflow.com": { "vendor": "Mouseflow", "category": "session-recording", "consent": "required" },
    "cdn.smartlook.com": { "vendor": "Smartlook", "category": "session-recording", "consent": "required" },
    "js.hs-scripts.com": { "vendor": "HubSpot", "category": "analytics", "consent": "required", "note": "HubSpot tracking + chat; recipient/CRM (Area E/K)" },
    "js.hs-analytics.net": { "vendor": "HubSpot", "category": "analytics", "consent": "required" },
    "track.hubspot.com": { "vendor": "HubSpot", "category": "analytics", "consent": "required" },
    "cdn.rudderlabs.com": { "vendor": "RudderStack", "category": "analytics", "consent": "required", "note": "customer-data pipeline" },
    "cdn.segment.com": { "vendor": "Segment", "category": "analytics", "consent": "required", "note": "customer-data pipeline; fans out to many vendors" },
    "api.segment.io": { "vendor": "Segment", "category": "analytics", "consent": "required" },
    "widget.intercom.io": { "vendor": "Intercom", "category": "analytics", "consent": "required", "note": "chat + tracking" },
    "connect.facebook.com": { "vendor": "Meta", "category": "social", "consent": "required" },
    "platform.twitter.com": { "vendor": "X (Twitter)", "category": "social", "consent": "required" },
    "www.youtube.com": { "vendor": "Google", "category": "social", "consent": "required", "note": "YouTube embed — use youtube-nocookie to reduce" },
    "www.instagram.com": { "vendor": "Meta", "category": "social", "consent": "required" },
    "fonts.googleapis.com": { "vendor": "Google", "category": "fonts", "consent": "required", "note": "Google Fonts CSS — leaks IP (E-04); self-host to avoid" },
    "fonts.gstatic.com": { "vendor": "Google", "category": "fonts", "consent": "required", "note": "Google Fonts files" },
    "use.typekit.net": { "vendor": "Adobe", "category": "fonts", "consent": "required" },
    "www.google.com": { "vendor": "Google", "category": "captcha", "consent": "required", "note": "reCAPTCHA (recaptcha/ path) — leaks IP (E-07)" },
    "www.gstatic.com": { "vendor": "Google", "category": "captcha", "consent": "required", "note": "reCAPTCHA assets" },
    "hcaptcha.com": { "vendor": "hCaptcha", "category": "captcha", "consent": "required" },
    "challenges.cloudflare.com": { "vendor": "Cloudflare", "category": "captcha", "consent": "technical", "note": "Turnstile — privacy-preserving, usually technical" }
  },
  "pixelPaths": [
    { "match": "facebook.com/tr", "vendor": "Meta", "signal": "Meta Pixel fire" },
    { "match": "google-analytics.com/g/collect", "vendor": "Google", "signal": "GA4 hit" },
    { "match": "google-analytics.com/collect", "vendor": "Google", "signal": "GA hit" },
    { "match": "google-analytics.com/j/collect", "vendor": "Google", "signal": "GA hit (measurement)" },
    { "match": "googleadservices.com/pagead/conversion", "vendor": "Google", "signal": "Google Ads conversion" },
    { "match": "px.ads.linkedin.com/collect", "vendor": "LinkedIn", "signal": "LinkedIn Insight fire" },
    { "match": "analytics.tiktok.com/api", "vendor": "TikTok", "signal": "TikTok pixel fire" },
    { "match": "bat.bing.com/action", "vendor": "Microsoft", "signal": "Bing UET fire" }
  ],
  "fingerprintApis": [
    "HTMLCanvasElement.prototype.toDataURL",
    "HTMLCanvasElement.prototype.getImageData",
    "CanvasRenderingContext2D.prototype.getImageData",
    "AudioContext",
    "OfflineAudioContext",
    "navigator.getBattery",
    "document.fonts.check"
  ]
}
